<%
  sev_colors    = { 'info' => '#17a2b8', 'warning' => '#fd7e14', 'error' => '#dc3545', 'critical' => '#7b001c' }
  status_colors = { 'open' => '#dc3545', 'in_progress' => '#fd7e14', 'resolved' => '#28a745', 'ignored' => '#6c757d' }
%>

<style>
  .er-show-header { margin-bottom: 20px; }
  .er-show-header h1 { font-size: 16px; margin: 0 0 6px; display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .er-show-meta { font-size: 13px; color: #6b7280; }
  .er-show-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; }
  .er-detail-table th { width: 150px; color: #6b7280; font-weight: 500; vertical-align: top; }
  .er-detail-table td { word-break: break-word; }
  .er-pre { white-space: pre-wrap; background: #f8fafc; padding: 12px; border-radius: 8px;
            max-height: 360px; overflow: auto; font-size: 11px; font-family: ui-monospace, monospace; margin: 0; }
  .er-status-actions { display: flex; gap: 8px; align-items: flex-start; flex-wrap: wrap; }
  .er-btn { padding: 8px 16px; border: 0; border-radius: 8px; color: #fff; cursor: pointer; font-size: 13px; }
  .er-btn:hover { opacity: .85; }
  .er-btn-danger { background: #1f2933; }
  .resolve-inline { margin-top: 10px; display: none; }
  .resolve-inline textarea { width: 320px; padding: 7px 10px; border: 1px solid #d1d5db; border-radius: 7px;
                              font-size: 13px; resize: vertical; }
  .resolve-inline button { margin-top: 6px; padding: 6px 14px; background: #28a745; color: #fff;
                            border: 0; border-radius: 6px; cursor: pointer; font-size: 13px; }
  @media (max-width: 768px) { .er-show-grid { grid-template-columns: 1fr; } }
</style>

<div class="sub"><%= link_to '← All Errors', errors_path %></div>

<div class="er-show-header">
  <h1>
    <span class="badge" style="background:<%= status_colors[@error.status] %>"><%= @error.status.humanize %></span>
    <span class="badge" style="background:<%= sev_colors[@error.severity] %>"><%= @error.severity %></span>
    <span style="font-family:ui-monospace,monospace"><%= @error.error_class %></span>
  </h1>
  <div class="er-show-meta">
    <%= @error.category.to_s.humanize %> ·
    <strong>×<%= @error.occurrences %></strong> occurrences ·
    last seen <strong><%= @error.last_seen_at&.strftime('%Y-%m-%d %H:%M') %></strong>
  </div>
</div>

<%# ── Details ── %>
<div class="panel">
  <h2>Details</h2>
  <table class="er-detail-table">
    <tr><th>Error class</th><td style="font-family:monospace"><%= @error.error_class %></td></tr>
    <tr><th>Source</th><td><%= @error.source %></td></tr>
    <tr><th>Category</th><td><%= @error.category.to_s.humanize %></td></tr>
    <tr><th>Message</th><td style="white-space:pre-wrap"><%= @error.message %></td></tr>
    <tr><th>Occurrences</th><td><strong><%= @error.occurrences %></strong></td></tr>
    <tr><th>First seen</th><td><%= @error.first_seen_at&.strftime('%Y-%m-%d %H:%M:%S %Z') %></td></tr>
    <tr><th>Last seen</th><td><%= @error.last_seen_at&.strftime('%Y-%m-%d %H:%M:%S %Z') %></td></tr>
    <% if @error.http_status.present? || @error.api_code.present? %>
      <tr><th>HTTP status</th><td><%= @error.http_status %></td></tr>
      <% if @error.api_code.present? %>
        <tr><th>API code / subcode</th><td><%= @error.api_code %> / <%= @error.api_subcode %></td></tr>
      <% end %>
      <% if @error.request_url.present? %>
        <tr><th>Request URL</th><td style="word-break:break-all"><%= @error.request_url %></td></tr>
      <% end %>
    <% end %>
    <% if @error.resolved_at.present? %>
      <tr><th>Resolved at</th><td><%= @error.resolved_at&.strftime('%Y-%m-%d %H:%M:%S') %> by <%= @error.resolved_by %></td></tr>
      <% if @error.resolution_note.present? %>
        <tr><th>Resolution note</th><td><%= @error.resolution_note %></td></tr>
      <% end %>
    <% end %>
  </table>
</div>

<%# ── Context + Backtrace side by side ── %>
<div class="er-show-grid">
  <div class="panel">
    <h2>Context</h2>
    <pre class="er-pre"><%= JSON.pretty_generate(@error.context || {}) %></pre>
  </div>
  <div class="panel">
    <h2>Backtrace</h2>
    <pre class="er-pre"><%= @error.backtrace %></pre>
  </div>
</div>

<%# ── Status change ── %>
<div class="panel" style="margin-top:16px">
  <h2>Change status</h2>
  <div class="er-status-actions">
    <% %w[open in_progress ignored].each do |s| %>
      <button class="er-btn status-btn" data-status="<%= s %>"
              style="background:<%= status_colors[s] %>">
        <%= s.humanize %>
      </button>
    <% end %>

    <div>
      <button class="er-btn" style="background:#28a745" onclick="toggleResolveBox(event)">Resolve</button>
      <div class="resolve-inline" id="resolve-box">
        <textarea id="resolve-note" rows="3" placeholder="Resolution note (optional)…"></textarea><br>
        <button onclick="doResolve()">Confirm resolve</button>
      </div>
    </div>

    <div style="flex:1"></div>
    <button class="er-btn er-btn-danger" onclick="doDelete()">Delete</button>
  </div>
</div>

<%# ── Occurrences History ── %>
<% if ErrorRadar.config.track_occurrences %>
  <div class="panel" style="margin-top:16px" id="occurrences-panel">
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:12px">
      <h2 style="margin:0">Occurrence History
        <% if @occ_total.to_i > 0 %>
          <span style="font-size:13px;font-weight:400;color:#6b7280">(<%= @occ_total %> total)</span>
        <% end %>
      </h2>
    </div>

    <% if @occurrences.empty? %>
      <p style="font-size:13px;color:#9ca3af;margin:0">
        <% if @occ_total.to_i == 0 %>
          No occurrences recorded yet. New hits will appear here.
        <% else %>
          No occurrences on this page.
        <% end %>
      </p>
    <% else %>
      <table style="width:100%;border-collapse:collapse;font-size:13px">
        <thead>
          <tr style="border-bottom:2px solid #e5e7eb">
            <th style="text-align:left;padding:6px 8px;color:#6b7280;width:170px">Time</th>
            <th style="text-align:left;padding:6px 8px;color:#6b7280;width:70px">HTTP</th>
            <th style="text-align:left;padding:6px 8px;color:#6b7280">Context / Request</th>
            <th style="text-align:left;padding:6px 8px;color:#6b7280;width:80px">Backtrace</th>
          </tr>
        </thead>
        <tbody>
          <% @occurrences.each_with_index do |occ, i| %>
            <tr style="border-bottom:1px solid #f3f4f6" class="occ-row">
              <td style="padding:7px 8px;font-family:monospace;font-size:11px;white-space:nowrap">
                <%= occ.occurred_at&.strftime('%Y-%m-%d %H:%M:%S') %>
              </td>
              <td style="padding:7px 8px">
                <% if occ.http_status.present? %>
                  <span class="badge" style="background:<%= occ.http_status.to_i >= 500 ? '#dc3545' : '#fd7e14' %>">
                    <%= occ.http_status %>
                  </span>
                <% end %>
              </td>
              <td style="padding:7px 8px;max-width:400px">
                <% if occ.request_url.present? %>
                  <div style="font-size:11px;color:#6b7280;word-break:break-all;margin-bottom:4px"><%= occ.request_url.truncate(120) %></div>
                <% end %>
                <% unless (occ.context || {}).empty? %>
                  <button onclick="toggleOcc('ctx-<%= i %>')"
                          style="padding:2px 8px;font-size:11px;border:1px solid #d1d5db;border-radius:4px;background:#f9fafb;cursor:pointer">
                    Context ▾
                  </button>
                  <div id="ctx-<%= i %>" style="display:none;margin-top:6px">
                    <pre class="er-pre" style="max-height:200px;font-size:10px"><%= occ.context_pretty %></pre>
                  </div>
                <% end %>
              </td>
              <td style="padding:7px 8px">
                <% if occ.backtrace.present? %>
                  <button onclick="toggleOcc('bt-<%= i %>')"
                          style="padding:2px 8px;font-size:11px;border:1px solid #d1d5db;border-radius:4px;background:#f9fafb;cursor:pointer">
                    Stack ▾
                  </button>
                  <div id="bt-<%= i %>" style="display:none;position:absolute;z-index:10;background:#fff;border:1px solid #e5e7eb;border-radius:8px;padding:12px;width:600px;max-width:90vw;box-shadow:0 4px 16px rgba(0,0,0,.12)">
                    <pre class="er-pre" style="max-height:300px"><%= occ.backtrace %></pre>
                    <button onclick="toggleOcc('bt-<%= i %>')" style="margin-top:6px;font-size:11px;border:0;background:none;cursor:pointer;color:#6b7280">Close</button>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <%# Pagination %>
      <% if @occ_total_pages.to_i > 1 %>
        <div style="margin-top:12px;display:flex;gap:6px;font-size:12px;align-items:center">
          <% (1..@occ_total_pages).each do |p| %>
            <% if p == @occ_page %>
              <span style="padding:4px 10px;background:#2563eb;color:#fff;border-radius:6px"><%= p %></span>
            <% else %>
              <%= link_to p, error_path(@error, occ_page: p, anchor: 'occurrences-panel'),
                    style: 'padding:4px 10px;border:1px solid #d1d5db;border-radius:6px;text-decoration:none;color:#374151' %>
            <% end %>
          <% end %>
          <span style="color:#9ca3af">of <%= @occ_total_pages %> pages</span>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>

<%# ── GitHub Issue ── %>
<% if ErrorRadar.config.github_token.present? && ErrorRadar.config.github_repo.present? %>
  <div class="panel" style="margin-top:16px">
    <h2>GitHub</h2>
    <% has_col = @error.class.column_names.include?('github_issue_url') %>
    <% if has_col && @error.github_issue_url.present? %>
      <a href="<%= @error.github_issue_url %>" target="_blank" rel="noopener"
         class="er-btn" style="background:#24292e;display:inline-block;text-decoration:none">
        &#9651; View GitHub Issue
      </a>
    <% else %>
      <button id="github-btn" class="er-btn" style="background:#24292e" onclick="createGithubIssue()">
        &#9651; Create GitHub Issue
      </button>
      <span id="github-status" style="font-size:13px;color:#6b7280;margin-left:10px"></span>
      <% unless has_col %>
        <p style="font-size:12px;color:#9ca3af;margin:10px 0 0">
          Run <code style="background:#f3f4f6;padding:2px 6px;border-radius:4px">bin/rails generate error_radar:upgrade_v050 &amp;&amp; bin/rails db:migrate</code>
          to enable issue tracking.
        </p>
      <% end %>
    <% end %>
  </div>
<% end %>

<%# ── Assignment, Comments & Activity ── %>
<% if @has_v100 %>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:16px">

    <%# Assignment %>
    <div class="panel" id="assignment-panel">
      <h2>Assignment</h2>
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
        <div id="assignee-display" style="font-size:14px;color:#374151">
          <% if @error.assigned_to.present? %>
            Assigned to <strong><%= @error.assigned_to %></strong>
          <% else %>
            <span style="color:#9ca3af">Unassigned</span>
          <% end %>
        </div>
        <button onclick="toggleAssignForm()"
                style="padding:4px 12px;font-size:12px;border:1px solid #d1d5db;border-radius:6px;background:#f9fafb;cursor:pointer">
          Change
        </button>
      </div>
      <div id="assign-form" style="display:none;margin-top:10px">
        <input id="assignee-input" type="text" value="<%= @error.assigned_to %>"
               placeholder="Name or email…"
               style="padding:6px 10px;border:1px solid #d1d5db;border-radius:6px;font-size:13px;width:200px">
        <button onclick="doAssign()"
                style="margin-left:6px;padding:6px 14px;background:#2563eb;color:#fff;border:0;border-radius:6px;font-size:13px;cursor:pointer">
          Save
        </button>
        <button onclick="toggleAssignForm()"
                style="margin-left:4px;padding:6px 10px;background:#f3f4f6;color:#374151;border:1px solid #d1d5db;border-radius:6px;font-size:13px;cursor:pointer">
          Cancel
        </button>
      </div>
    </div>

    <%# Activity timeline %>
    <div class="panel" id="activity-panel">
      <h2>Activity <span style="font-size:12px;font-weight:400;color:#9ca3af">(<%= @activities.size %> events)</span></h2>
      <% if @activities.empty? %>
        <p style="font-size:13px;color:#9ca3af;margin:0">No activity yet.</p>
      <% else %>
        <div style="max-height:280px;overflow-y:auto">
          <% @activities.each do |act| %>
            <div style="display:flex;gap:8px;padding:6px 0;border-bottom:1px solid #f3f4f6;font-size:12px">
              <span style="font-size:14px;min-width:20px;text-align:center"><%= act.icon %></span>
              <div style="flex:1">
                <span style="font-weight:600;color:#374151"><%= act.action %></span>
                <% if act.detail.present? %>
                  <span style="color:#6b7280"> — <%= act.detail.truncate(80) %></span>
                <% end %>
                <div style="color:#9ca3af;font-size:11px;margin-top:1px">
                  <% if act.actor.present? %><%= act.actor %> · <% end %>
                  <%= act.created_at&.strftime('%Y-%m-%d %H:%M') %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Comments %>
  <div class="panel" style="margin-top:16px" id="comments-panel">
    <h2>Comments <span style="font-size:12px;font-weight:400;color:#9ca3af">(<%= @comments.size %>)</span></h2>

    <div id="comments-list">
      <% @comments.each do |cmt| %>
        <div class="er-comment" id="comment-<%= cmt.id %>"
             style="border:1px solid #e5e7eb;border-radius:8px;padding:12px 14px;margin-bottom:10px">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px">
            <div style="font-size:12px;font-weight:600;color:#374151"><%= cmt.author.presence || 'Anonymous' %></div>
            <div style="display:flex;gap:8px;align-items:center">
              <span style="font-size:11px;color:#9ca3af"><%= cmt.created_at&.strftime('%Y-%m-%d %H:%M') %></span>
              <button onclick="deleteComment(<%= cmt.id %>)"
                      style="font-size:11px;color:#dc3545;background:none;border:0;cursor:pointer;padding:0">✕</button>
            </div>
          </div>
          <div style="font-size:13px;color:#1f2937;white-space:pre-wrap"><%= cmt.body %></div>
        </div>
      <% end %>
    </div>

    <div style="margin-top:12px">
      <textarea id="comment-body" rows="3" placeholder="Add a comment…"
                style="width:100%;padding:8px 12px;border:1px solid #d1d5db;border-radius:8px;font-size:13px;resize:vertical;box-sizing:border-box"></textarea>
      <div style="margin-top:6px;display:flex;justify-content:flex-end">
        <button onclick="submitComment()"
                style="padding:7px 18px;background:#2563eb;color:#fff;border:0;border-radius:8px;font-size:13px;cursor:pointer">
          Add comment
        </button>
      </div>
    </div>
  </div>

<% else %>
  <div class="panel" style="margin-top:16px">
    <h2>Assignment, Comments &amp; Activity (v1.0.0)</h2>
    <p style="font-size:13px;color:#6b7280;margin:0">
      Run the upgrade migration to enable these features:
    </p>
    <code style="display:block;margin-top:8px;background:#f3f4f6;padding:10px 14px;border-radius:8px;font-size:12px">
      bin/rails generate error_radar:upgrade_v100 &amp;&amp; bin/rails db:migrate
    </code>
  </div>
<% end %>

<script>
  window.toggleOcc = function (id) {
    var el = document.getElementById(id);
    if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none';
  };

(function () {
  var CSRF       = document.querySelector('meta[name="csrf-token"]').content;
  var STATUS_URL = '<%= error_status_path(@error) %>';
  var DELETE_URL = '<%= error_path(@error) %>';
  var GITHUB_URL = '<%= error_github_issue_path(@error) %>';

  document.querySelectorAll('.status-btn').forEach(function (btn) {
    btn.addEventListener('click', function () { changeStatus(btn.dataset.status, null); });
  });

  window.toggleResolveBox = function (e) {
    e.preventDefault();
    var box = document.getElementById('resolve-box');
    box.style.display = box.style.display === 'none' ? 'block' : 'none';
  };

  window.doResolve = function () {
    changeStatus('resolved', document.getElementById('resolve-note').value.trim() || null);
  };

  function changeStatus(status, note) {
    var body = { status: status };
    if (note) body.note = note;
    fetch(STATUS_URL, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
      body: JSON.stringify(body)
    })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.ok) {
        showToast('→ ' + d.status, true);
        setTimeout(function () { location.reload(); }, 700);
      } else {
        showToast('Error: ' + (d.error || 'failed'), false);
      }
    });
  }

  window.doDelete = function () {
    if (!confirm('Permanently delete this error? This cannot be undone.')) return;
    fetch(DELETE_URL, {
      method: 'DELETE',
      headers: { 'X-CSRF-Token': CSRF }
    })
    .then(function (r) {
      if (r.ok) { window.location.href = '<%= errors_path %>'; }
    });
  };

  // ── Assignment ──
  var ASSIGN_URL  = '<%= respond_to?(:error_assign_path) ? error_assign_path(@error) : "" %>';
  var COMMENT_URL = '<%= respond_to?(:error_comments_path) ? error_comments_path(@error) : "" %>';

  window.toggleAssignForm = function () {
    var f = document.getElementById('assign-form');
    if (f) f.style.display = f.style.display === 'none' ? 'block' : 'none';
  };

  window.doAssign = function () {
    var val = document.getElementById('assignee-input').value.trim();
    fetch(ASSIGN_URL, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
      body: JSON.stringify({ assigned_to: val })
    }).then(function (r) { return r.json(); })
      .then(function (d) {
        if (d.ok) {
          var disp = document.getElementById('assignee-display');
          disp.innerHTML = d.assigned_to
            ? 'Assigned to <strong>' + d.assigned_to + '</strong>'
            : '<span style="color:#9ca3af">Unassigned</span>';
          toggleAssignForm();
          appendActivity({ icon: '→', action: d.assigned_to ? 'assigned → ' + d.assigned_to : 'unassigned' });
          showToast(d.assigned_to ? 'Assigned to ' + d.assigned_to : 'Unassigned', true);
        } else {
          showToast(d.error || 'Failed', false);
        }
      });
  };

  // ── Comments ──
  window.submitComment = function () {
    var body = document.getElementById('comment-body').value.trim();
    if (!body) { showToast('Comment cannot be blank', false); return; }

    fetch(COMMENT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
      body: JSON.stringify({ body: body })
    }).then(function (r) { return r.json(); })
      .then(function (d) {
        if (d.ok) {
          document.getElementById('comment-body').value = '';
          var list = document.getElementById('comments-list');
          list.insertAdjacentHTML('beforeend',
            '<div class="er-comment" id="comment-' + d.id + '" style="border:1px solid #e5e7eb;border-radius:8px;padding:12px 14px;margin-bottom:10px">' +
            '<div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px">' +
            '<div style="font-size:12px;font-weight:600;color:#374151">' + (d.author || 'Anonymous') + '</div>' +
            '<div style="display:flex;gap:8px;align-items:center">' +
            '<span style="font-size:11px;color:#9ca3af">' + d.created_at + '</span>' +
            '<button onclick="deleteComment(' + d.id + ')" style="font-size:11px;color:#dc3545;background:none;border:0;cursor:pointer;padding:0">✕</button>' +
            '</div></div>' +
            '<div style="font-size:13px;color:#1f2937;white-space:pre-wrap">' + escHtml(d.body) + '</div>' +
            '</div>'
          );
          appendActivity({ icon: '💬', action: 'commented', detail: d.body.substring(0, 80) });
          updateCommentCount(1);
          showToast('Comment added', true);
        } else {
          showToast(d.error || 'Failed', false);
        }
      });
  };

  window.deleteComment = function (id) {
    if (!confirm('Delete this comment?')) return;
    fetch('<%= respond_to?(:error_comment_path) ? error_path(@error) : "" %>/comments/' + id, {
      method: 'DELETE',
      headers: { 'X-CSRF-Token': CSRF }
    }).then(function (r) {
      if (r.ok) {
        var el = document.getElementById('comment-' + id);
        if (el) el.remove();
        appendActivity({ icon: '🗑', action: 'comment_deleted' });
        updateCommentCount(-1);
        showToast('Comment deleted', true);
      }
    });
  };

  function updateCommentCount(delta) {
    var h2 = document.querySelector('#comments-panel h2');
    if (!h2) return;
    var match = h2.textContent.match(/(\d+)/);
    if (match) {
      var n = parseInt(match[1], 10) + delta;
      h2.innerHTML = 'Comments <span style="font-size:12px;font-weight:400;color:#9ca3af">(' + n + ')</span>';
    }
  }

  function appendActivity(act) {
    var list = document.querySelector('#activity-panel [style*="max-height"]');
    var empty = document.querySelector('#activity-panel p');
    if (empty) { empty.remove(); }
    if (!list) {
      var panel = document.querySelector('#activity-panel');
      if (!panel) return;
      list = document.createElement('div');
      list.style.cssText = 'max-height:280px;overflow-y:auto';
      panel.appendChild(list);
    }
    var now = new Date();
    var ts = now.getFullYear() + '-' + String(now.getMonth()+1).padStart(2,'0') + '-' + String(now.getDate()).padStart(2,'0') + ' ' + String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0');
    list.insertAdjacentHTML('afterbegin',
      '<div style="display:flex;gap:8px;padding:6px 0;border-bottom:1px solid #f3f4f6;font-size:12px">' +
      '<span style="font-size:14px;min-width:20px;text-align:center">' + (act.icon || '·') + '</span>' +
      '<div style="flex:1"><span style="font-weight:600;color:#374151">' + act.action + '</span>' +
      (act.detail ? '<span style="color:#6b7280"> — ' + escHtml(act.detail) + '</span>' : '') +
      '<div style="color:#9ca3af;font-size:11px;margin-top:1px">' + ts + '</div></div></div>'
    );
  }

  function escHtml(str) {
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  window.createGithubIssue = function () {
    var btn    = document.getElementById('github-btn');
    var status = document.getElementById('github-status');
    if (!btn) return;
    btn.disabled    = true;
    status.textContent = 'Creating issue…';

    fetch(GITHUB_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF }
    })
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (d.ok) {
        status.innerHTML = '✓ Created: <a href="' + d.url + '" target="_blank">#' + d.number + '</a>';
        btn.style.display = 'none';
        showToast('GitHub issue #' + d.number + ' created', true);
      } else {
        status.textContent = 'Error: ' + (d.error || 'failed');
        btn.disabled = false;
        showToast(d.error || 'GitHub error', false);
      }
    })
    .catch(function () {
      status.textContent = 'Network error';
      btn.disabled = false;
    });
  };

  function showToast(msg, ok) {
    var t = document.getElementById('toast');
    t.textContent = msg;
    t.style.background = ok ? '#16a34a' : '#dc2626';
    t.classList.add('show');
    setTimeout(function () { t.classList.remove('show'); }, 2000);
  }
})();
</script>
